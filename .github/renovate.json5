{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>canonical/data-platform//renovate_presets/charm.json5",
  ],
  "reviewers": [
    "welpaolo",
    "theoctober19th",
    "batalex",
  ],
  "baseBranchPatterns": ["/^track\\/[0-9]+\\.[0-9]+$/"],
  "schedule": ["* 3 * * 5"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["* 3 * * 5"]
  },
  "ignoreDeps": ["ubuntu"],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "matchDepNames": ["python"],
      "enabled": false
    }
  ],
}
